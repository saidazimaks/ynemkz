# Telegram
BOT_TOKEN=123456:ABC-DEF...
ADMIN_IDS=111111111,222222222
# Секрет для /admin_access <секрет> — выдаёт роль admin. Пусто = отключено.
ADMIN_SECRET=

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=service_role_key_here
# Прямое подключение к Postgres (для asyncpg pool)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
# Bucket для чеков Kaspi и логотипов
STORAGE_BUCKET=receipts

# Платежи
KASPI_PHONE=+7 700 000 00 00
SUBSCRIPTION_PRICE=2000
# Цена в Telegram Stars (XTR). 1 Star ≈ $0.02 для пользователя, разработчику
# доходит ~$0.013: 250 Stars ≈ 2600 ₸ для пользователя, на руки ≈ 1700 ₸ —
# чуть меньше Kaspi-цены, зато активация мгновенная и без ручной проверки
SUBSCRIPTION_PRICE_STARS=250

# Mini App (Vercel), без слэша на конце — используется в CORS и web_app-кнопках
MINIAPP_URL=https://vygodny-gorod.vercel.app

# Прочее
DEFAULT_LANG=ru
